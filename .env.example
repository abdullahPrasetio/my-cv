# Database
DB_NAME=cvplatform
DB_USER=cvuser
DB_PASSWORD=ganti_password_kuat_disini

# JWT (min 32 karakter)
JWT_SECRET=ganti_jwt_secret_panjang_dan_acak_minimal_32_karakter

# Cloudflare R2 Storage
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY=
CF_R2_SECRET_KEY=
CF_R2_BUCKET=cv-media
CF_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Cloudflare Tunnel Token (dari: cloudflared tunnel token <nama-tunnel>)
CF_TUNNEL_TOKEN=

# URL API untuk admin panel (ganti domain.com dengan domain kamu)
NUXT_PUBLIC_API_URL=https://domain.com/api/v1

# App
APP_ENV=production
